{
  "_meta": {
    "schema_version": 1,
    "created_at": "2026-05-23T15:33:00",
    "marker": "P5-fix53",
    "purpose": "[SENSOR STATE] block 字段配置 — 主脑 prompt 注入 Sir 真实物理状态. 准则 6 持久化 + 准则 8 优雅, Sir 15:31 设计指示.",
    "consumer": "jarvis_sensor_state_block.build_sensor_state_block",
    "edit_via": "scripts/sensor_state_dump.py --list / --activate <field> / --reject <field>",
    "tier_design": "按 prompt tier 注入子集. SHORT_CHAT 紧凑 (4-6 核心字段), CHAT 中等 (8-10), DEEP_QUERY 全量 (13+). 主脑 reply 复杂程度匹配 evidence 量.",
    "field_naming_rule": "命名严格语义清晰. e.g. current_window_stay_s (per-app, 秒) vs work_session_total_min (整 session, 分). Sir 15:27 真痛点根因 = 字段语义不清晰主脑误用."
  },
  "fields": [
    {
      "id": "active_window",
      "source": "PhysicalEnvironmentProbe.current_window_title",
      "transform": "str_truncate_80",
      "label": "active_window",
      "annotation": "Sir 当前在看的 window 标题",
      "tiers": ["SHORT_CHAT", "CHAT", "DEEP_QUERY"],
      "active": true,
      "format": "\"{value}\""
    },
    {
      "id": "process",
      "source": "PhysicalEnvironmentProbe.current_process_name",
      "transform": "str_truncate_40",
      "label": "process",
      "annotation": "active 进程名",
      "tiers": ["SHORT_CHAT", "CHAT", "DEEP_QUERY"],
      "active": true
    },
    {
      "id": "work_category",
      "source": "PhysicalEnvironmentProbe.current_work_category",
      "transform": "str_default_idle",
      "label": "work_category",
      "annotation": "分类: Coding/Reading/Writing/Communication/Media/Idle...",
      "tiers": ["SHORT_CHAT", "CHAT", "DEEP_QUERY"],
      "active": true
    },
    {
      "id": "current_window_stay_s",
      "source": "PhysicalEnvironmentProbe.current_window_stay_seconds",
