# =============================================================================
# Jarvis Personal Butler — .env.example
# =============================================================================
# 用法：
#   1. cp .env.example .env  （或 PowerShell: Copy-Item .env.example .env）
#   2. 编辑 .env 把 REPLACE_ME 换成真实 keys
#   3. .env 永远不要 commit（.gitignore 已排除）
#
# Rotate 规则（参考 docs/NERVE_SPLIT_PLAN.md §P0+19-deps Step D）：
#   - 在 OpenRouter / Google AI Studio 控制台先新建 keys 但不删旧
#   - 验通新 keys 再删旧
#
# ⚠️ 安全铁律：本文件会被 commit 进 git，所以这里 8 个 REPLACE_ME 永远不准换成真实 key！
# =============================================================================

# --- OpenRouter（主脑 LLM） ---
# 主脑专用 key（KeyRouter 锁死、绝不与其他模块共享）
OPENROUTER_MAIN=REPLACE_ME

# 副 key 池（4 个，KeyRouter 随机抽取 + 失败切换）
OPENROUTER_2=REPLACE_ME
OPENROUTER_3=REPLACE_ME
OPENROUTER_4=REPLACE_ME
OPENROUTER_5=REPLACE_ME

# --- Google Gemini（海马体 embedding / Gatekeeper / 部分子任务）---
# 主 Gemini key
GEMINI_KEY=REPLACE_ME

# Google key 池（3 个，应来自**不同 Project**避免 PROJECT_DENIED 一损俱损）
GOOGLE_KEY_2=REPLACE_ME
GOOGLE_KEY_3=REPLACE_ME

# --- 代理（可选）---
# 若需走代理（如 clash 7890）：
# JARVIS_HTTP_PROXY=http://127.0.0.1:7890
# JARVIS_HTTPS_PROXY=http://127.0.0.1:7890
