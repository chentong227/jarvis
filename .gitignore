# =============================================================================
# Jarvis Personal Butler -- .gitignore
# =============================================================================
# Order: secrets first -> runtime data -> Python/IDE leftovers
#
# Security rule: NEVER commit anything containing real API keys,
#                personal info, or login credentials.
#
# Important: .gitignore does NOT support inline comments. A pattern like
#   `foo # comment`  will be treated as the literal pattern "foo # comment",
# which silently fails to match. Therefore every comment is on its own line.
# =============================================================================


# === SECRETS ===
.env
.env.local
.env.*.local
*.pem
*.key
secrets.json
credentials.json


# === jarvis_config sensitive data ===
# Note: jarvis_config/keys.py is a pure dotenv loader (only imports os.environ),
# it MUST be committed, otherwise `from jarvis_config.keys import load_keys`
# fails after a fresh clone.
# Bilibili login session (~135KB)
jarvis_config/bilibili_auth.json
# Sir personal profile (~17KB)
jarvis_config/sir_profile.json
jarvis_config/*_auth.json
jarvis_config/*.token
# local cache like keys.local.json
jarvis_config/keys.*.json


# === Runtime data ===
memory_pool/*.db
memory_pool/*.db-shm
memory_pool/*.db-wal
# skill_registry.jsonl is a runtime artifact
memory_pool/*.jsonl
# [P0+20-β.0.1 / 2026-05-16] directive 计数器（fired/rejected/helped）：runtime 状态
memory_pool/directive_registry.json
memory_pool/directive_review.json
# [P0+20-β.1.5 / 2026-05-16] KeyRouter 永久剔除持久化：runtime 状态
memory_pool/key_router_state.json
# [P0+20-β.2.1 / 2026-05-16] Concerns Layer 1 持久化 + Sir review 队列：runtime 状态
memory_pool/concerns.json
memory_pool/concerns_review.json
# [P0+20-β.2.2 / 2026-05-16] RelationalState Layer 2 持久化：runtime 状态（Sir CLI 录入的笑点/默契/未竟之事）
memory_pool/relational_state.json
# [P0+20-β.3.3 / 2026-05-17] RelationalState Layer 4 propose 队列：runtime 状态
memory_pool/relational_review.json
# PlanLedger 持久化：runtime 状态
memory_pool/plans.json
# [P0+20-β.2.8.5 / 2026-05-17] Jarvis 自承诺账本：含 jarvis_reply 真实对话片段, runtime 私人数据
memory_pool/jarvis_promise_log.json
# [P0+20-β.2.8.6 / 2026-05-17] HealthProbe 自检趋势数据 — runtime 时间序列
memory_pool/jarvis_health_history.jsonl
# [P0+20-β.4.5.1 / 2026-05-18] ClaimStatsDumper 跨进程持久化: in-memory counter snapshot
memory_pool/claim_stats.json
# [P5-fix20-A1/A2 / 2026-05-22] KeyRouter health snapshot + reset IPC + audit: runtime
memory_pool/key_router_health.json
memory_pool/key_router_reset_request.json
memory_pool/key_router_reset_audit.jsonl
# [β.5.46-fix14 / 2026-05-22] IntentResolver A/B telemetry: runtime stats snapshot
memory_pool/intent_resolver_telemetry.json
# [P5-IntegrityWatcher / 2026-05-21] runtime claim store + cross-session callback
memory_pool/integrity_watcher.json
memory_pool/claim_revisions.json
memory_pool/cross_session_callback.json
# [P5-SirStatusTracker / 2026-05-21] Sir 自报状态 + 已 ack runtime
memory_pool/sir_status.json
memory_pool/sir_acked_state.json
# [P5-Gap3 / 2026-05-21] ScreenVisionEngine 屏幕快照: runtime
memory_pool/screen_snapshot.json
# memory_pool 下的 .bak 文件 (jsonl tainted 备份 / promise_log 归档备份等 runtime 残留)
memory_pool/*.bak
# [Reshape M3.A / 2026-05-24] 扩 glob: conftest fix backup 等
memory_pool/*.bak.*
jarvis_config/screenshots/
jarvis_config/user_status_history/
jarvis_config/user_status_ledger.json
jarvis_config/jarvis_os_audit.log
jarvis_config/os_landmarks.json


# === Logs ===
docs/runtime_logs/
docs/funnel_logs/
*.log


# === Large binary assets (use Git LFS later, currently local) ===
ffmpeg.exe
ffprobe.exe
# CosyVoice / TTS model weights -- single file up to ~850MB, exceeds
# GitHub's 100MB hard limit and bloats clone time. Users should re-download
# them via install.bat or from the model hub. config.json / tokenizer.json
# stay in git as they are tiny and needed at load time.
*.safetensors
asset/**/*.safetensors
# all wav ignored ...
*.wav
# ... but keep ONLY the root-level jarvis_prompt.wav (5s TTS anchor audio).
# Leading slash anchors to repo root, so memory_pool/jarvis_prompt.wav etc.
# (which are runtime artifacts) stay ignored.
!/jarvis_prompt.wav
*.mp4
*.mkv


# === Python ===
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.tox/


# === Virtualenvs ===
.venv/
venv/
ENV/
env/
.python-version


# === IDE / Editor ===
.vscode/settings.json
.vscode/launch.json
.vscode/.ropeproject
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# === Cursor / Agent temp ===
# .cursor/ holds Cursor's local cache, but .cursor/rules/ contains project
# rules (committed to git, read by all AI agents). Use file-glob negation,
# NOT directory-glob (a directory-glob ignore short-circuits all child
# negations). See https://git-scm.com/docs/gitignore#_pattern_format
.cursor/*
!.cursor/rules/
.aider*


# === Third-party submodules / heavy deps ===
# CosyVoice is treated as a submodule, not committed here
CosyVoice/
# but keep the placeholder
!CosyVoice/.gitkeep


# === Test artifacts ===
tests/__pycache__/
tests/_test_output.txt
tests/benchmark_result.txt
tests/stress_output.txt
tests/stress_test_report.txt
# [P0+20-W.3 / 2026-05-16] last_run.json is the per-run test report,
# regenerated by _runall.ps1 / conftest.py every test session. Don't commit.
tests/last_run.json


# === Temp analysis files ===
# full pip freeze, local reference only
requirements.frozen.txt
# temp DB inspection script
_db_inspect.py
# P0+18-a.5 placeholder
test_dummy.txt


# === OS temp ===
nul
*.tmp

# === [P0+20-β.4.8 / 2026-05-19] Wake word 模型文件 (Sir 自训 / Sir 拷贝, 各机不同) ===
# Sir 自训 jarvis_v1.onnx 在 Colab 训, 各 machine 不同 sample/quality
# 内置 hey_jarvis_v0.1 第一次启动 openWakeWord 自动下载到 site-packages
# 不进 git: 模型 binary 大 (~200KB-1MB), 各 Sir 机器有自己版本
memory_pool/wakeword_models/*.onnx
memory_pool/wakeword_models/*.tflite
